## GitLab configuration settings
##! Nếu cần override cấu hình ngoài GITLAB_OMNIBUS_CONFIG trong docker-compose,
##! mount file này vào /etc/gitlab/gitlab.rb
##!
##! Lưu ý: GITLAB_OMNIBUS_CONFIG trong docker-compose.yml được ưu tiên trước file này.
##! File này chỉ dùng khi cần cấu hình bổ sung.

################################################################
## Core: Disable bundled services (using external containers)
################################################################

postgresql['enable'] = false
redis['enable'] = false

################################################################
## External Database (PostgreSQL 17)
################################################################

gitlab_rails['db_adapter'] = 'postgresql'
gitlab_rails['db_encoding'] = 'utf8'
gitlab_rails['db_host'] = 'postgres'
gitlab_rails['db_port'] = 5432
gitlab_rails['db_username'] = 'gitlab'
gitlab_rails['db_database'] = 'gitlabhq_production'

################################################################
## External Redis (Redis 7.4)
################################################################

gitlab_rails['redis_host'] = 'redis'
gitlab_rails['redis_port'] = 6379

################################################################
## GitLab NGINX
################################################################

nginx['listen_port'] = 80
nginx['listen_https'] = false

################################################################
## Monitoring
################################################################

alertmanager['listen_address'] = 'localhost:9093'

################################################################
## Email (uncomment và cấu hình khi cần)
################################################################

#gitlab_rails['smtp_enable'] = true
#gitlab_rails['smtp_address'] = "smtp.gmail.com"
#gitlab_rails['smtp_port'] = 587
#gitlab_rails['smtp_user_name'] = "your-email@gmail.com"
#gitlab_rails['smtp_password'] = "your-app-password"
#gitlab_rails['smtp_domain'] = "gmail.com"
#gitlab_rails['smtp_authentication'] = "login"
#gitlab_rails['smtp_enable_starttls_auto'] = true
#gitlab_rails['smtp_tls'] = false

#gitlab_rails['gitlab_email_from'] = 'gitlab@yourdomain.com'
